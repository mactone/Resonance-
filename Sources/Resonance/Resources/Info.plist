<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Resonance</string>
    <key>CFBundleDisplayName</key>
    <string>Resonance</string>
    <key>CFBundleIdentifier</key>
    <string>com.resonance.app</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Permissions -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Resonance 需要麥克風權限來錄製你的語音閃念。</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Resonance 需要語音辨識權限來將你的錄音轉換成文字。</string>
    <key>NSUserNotificationsUsageDescription</key>
    <string>Resonance 會在背景生成新文章時通知你。</string>

    <!-- Background Tasks -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.resonance.article-generation</string>
    </array>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>processing</string>
        <string>audio</string>
    </array>

    <!-- App Transport Security (allows HTTP for local/dev) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>api.anthropic.com</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
            </dict>
        </dict>
    </dict>

    <!-- UI Settings -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
